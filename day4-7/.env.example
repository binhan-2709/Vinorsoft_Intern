# ── Database (Day 5) ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=blog_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/blog_db

# ── JWT (Day 6) ───────────────────────────────────────────────────────
# Tạo secret key mạnh: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────
BLOG_DEBUG=false
BLOG_LOG_LEVEL=INFO
