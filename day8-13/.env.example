# ── Django Core ───────────────────────────────────────
DJANGO_SECRET_KEY=dien-chuoi-bao-mat-vao-day
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# ── Database (PostgreSQL) ─────────────────────────────
# Cú pháp: postgresql://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgresql://postgres:postgres@db:5432/shop_db

# ── Celery & Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Email Settings ────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@shop.com